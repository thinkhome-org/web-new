                },
                {
                  "type": "text",
                  "id": "ISZ5H",
                  "name": "mh1",
                  "fill": "#0f172a",
                  "content": "1. Jaké osobní údaje zpracováváme?",
                  "fontFamily": "Manrope",
                  "fontSize": 20,
                  "fontWeight": "800"
                },
                {
                  "type": "text",
                  "id": "iDdRC",
                  "name": "mp1",
                  "fill": "#334155",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Zpracováváme pouze ty osobní údaje, které nám sami poskytnete v souvislosti s využíváním našich služeb, uzavřením smlouvy nebo při komunikaci s námi. Jedná se zejména o:",
                  "lineHeight": 1.6,
                  "fontFamily": "Manrope",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "Zc91x",
                  "name": "ml1",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 6,
                  "children": [
                    {
                      "type": "text",
                      "id": "4vf8c",
                      "name": "ml1a",
                      "fill": "#334155",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "• Identifikační údaje: jméno a příjmení, IČO, DIČ.",
                      "lineHeight": 1.6,
                      "fontFamily": "Manrope",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "tK55i",
                      "name": "ml1b",
                      "fill": "#334155",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "• Kontaktní údaje: e-mailová adresa, telefonní číslo, doručovací a fakturační adresa.",
                      "lineHeight": 1.6,
                      "fontFamily": "Manrope",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "t7upn",
                      "name": "ml1c",
                      "fill": "#334155",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "• Údaje o objednávkách a platbách: historie objednávek, bankovní spojení.",
                      "lineHeight": 1.6,
                      "fontFamily": "Manrope",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "rectangle",
                  "id": "WYYLI",
                  "name": "ms2",
                  "fill": "#e2e8f0",
                  "width": "fill_container",
                  "height": 1
                },
