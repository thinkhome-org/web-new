                  "id": "9x5kR",
                  "name": "mh4",
                  "fill": "#0f172a",
                  "content": "4. Jak dlouho údaje uchováváme?",
                  "fontFamily": "Manrope",
                  "fontSize": 20,
                  "fontWeight": "800"
                },
                {
                  "type": "text",
                  "id": "8ZE3P",
                  "name": "mp4",
                  "fill": "#334155",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Vaše osobní údaje uchováváme pouze po dobu nezbytně nutnou:",
                  "lineHeight": 1.6,
                  "fontFamily": "Manrope",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "o1ToW",
                  "name": "ml4",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 6,
                  "children": [
                    {
                      "type": "text",
                      "id": "sJjSe",
                      "name": "ml4a",
                      "fill": "#334155",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "• Údaje nezbytné pro plnění smlouvy po dobu trvání smluvního vztahu a následně po dobu stanovenou účetními a daňovými zákony (zpravidla 10 let).",
                      "lineHeight": 1.6,
                      "fontFamily": "Manrope",
                      "fontSize": 14,
