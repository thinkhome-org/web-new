                    },
                    {
                      "type": "text",
                      "id": "g5XCB",
                      "name": "ml4b",
                      "fill": "#334155",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "• Údaje zpracovávané na základě oprávněného zájmu uchováváme po dobu trvání tohoto zájmu (např. případné sjednávání smluv nebo obrana práv).",
                      "lineHeight": 1.6,
                      "fontFamily": "Manrope",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
