                  "type": "text",
                  "id": "u4Kiq",
                  "name": "mh2",
                  "fill": "#0f172a",
                  "content": "2. Za jakým účelem údaje zpracováváme?",
                  "fontFamily": "Manrope",
                  "fontSize": 20,
                  "fontWeight": "800"
                },
                {
                  "type": "text",
                  "id": "iS7xb",
                  "name": "mp2",
                  "fill": "#334155",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Osobní údaje zpracováváme k následujícím účelům:",
                  "lineHeight": 1.6,
                  "fontFamily": "Manrope",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "VocjE",
                  "name": "ml2",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 6,
                  "children": [
                    {
                      "type": "text",
                      "id": "jPQa4",
                      "name": "ml2a",
                      "fill": "#334155",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "• Plnění smlouvy a poskytování služeb: Vyřízení vašich objednávek, fakturace, instalace a podpora. (Právní základ: plnění smlouvy).",
                      "lineHeight": 1.6,
                      "fontFamily": "Manrope",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "uSP0U",
                      "name": "ml2b",
                      "fill": "#334155",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "• Komunikace: Odpovědi na vaše dotazy zaslané přes kontaktní formulář nebo e-mail. (Právní základ: oprávněný zájem nebo příprava smlouvy).",
                      "lineHeight": 1.6,
                      "fontFamily": "Manrope",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "jYHkJ",
                      "name": "ml2c",
                      "fill": "#334155",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "• Plnění právních povinností: Vedení účetnictví a daňových záznamů. (Právní základ: plnění právní povinnosti).",
                      "lineHeight": 1.6,
                      "fontFamily": "Manrope",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "fTrb4",
                      "name": "ml2d",
                      "fill": "#334155",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "• Ochrana našich práv: Vymáhání pohledávek a řešení právních sporů. (Právní základ: oprávněný zájem).",
                      "lineHeight": 1.6,
                      "fontFamily": "Manrope",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "rectangle",
